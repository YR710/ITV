<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <!-- 视频播放器区域 - 全屏模式 -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:background="#000000">

        <com.google.android.exoplayer2.ui.PlayerView
            android:id="@+id/player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:resize_mode="fit"
            app:show_buffering="when_playing"
            app:use_controller="true"
            app:controller_auto_show="true"
            app:player_layout_id="@layout/exo_player_control_view" />

        <!-- 全屏按钮（覆盖层） -->
        <ImageButton
            android:id="@+id/fullscreen_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/fullscreen_icon"
            android:alpha="0.7"
            android:visibility="visible" />

    </FrameLayout>

    <!-- 当前播放频道名称 -->
    <TextView
        android:id="@+id/current_channel_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未播放"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="#1A1A1A"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_playing"
        android:drawablePadding="8dp" />

    <!-- 频道列表区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="vertical"
        android:background="#1E1E1E">

        <!-- 列表标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2D2D2D"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="频道列表"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/channel_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0个频道"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- 频道列表 RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

    </LinearLayout>

</LinearLayout>
